CONFIG_PACKAGE_luci-app-qbittorrent=m  # 丘比特下载器
#CONFIG_PACKAGE_luci-app-samba4=m      # Samba 4 共享文件系统
#CONFIG_PACKAGE_luci-app-ttyd=m        # TTYd 终端
CONFIG_PACKAGE_luci-app-zerotier=m     # ZeroTier 虚拟网络

